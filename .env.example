# ============================================
# JobMitra Backend - Environment Template
# Copy this file to .env.local, .env.dev, or .env.prod
# and fill in the actual values.
#
# To run:
#   Local:  APP_ENV=local python main.py  (default)
#   Dev:    APP_ENV=dev python main.py
#   Prod:   APP_ENV=prod python main.py
# ============================================

# App Environment (local | dev | prod)
APP_ENV=local

# Database
MONGO_URI=mongodb://localhost:27017/jobmitra_local

# Redis
REDIS_URL=redis://localhost:6379

# Server
HOST=0.0.0.0
PORT=8000

# Frontend URL
FRONTEND_URL=http://localhost:4200

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:4200

# JWT Authentication
JWT_SECRET_KEY=<generate-a-strong-secret-key>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100

# AI API Keys
OPENAI_API_KEY=<your-openai-api-key>
GEMINI_API_KEY=<your-gemini-api-key>
ANTHROPIC_API_KEY=<your-anthropic-api-key>

# Google OAuth
GOOGLE_CLIENT_ID=<your-google-client-id>

# Email (SMTP)
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<your-smtp-email>
SMTP_PASSWORD=<your-smtp-app-password>
FROM_EMAIL=<your-from-email>
APP_NAME=JobMouka

# Logging (debug | info | warning | error)
LOG_LEVEL=info

APP_ENV=dev
LOG_LEVEL=info

# MongoDB Atlas (replace with your Atlas connection string)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/jobmitra

# Redis (replace with your Redis URL, e.g. Redis Cloud or Memorystore)
REDIS_URL=redis://<host>:6379

# JWT
JWT_SECRET_KEY=<strong-random-secret>

# CORS — your frontend dev domain
CORS_ORIGINS=https://dev.jobmouka.com,http://localhost:4200
FRONTEND_URL=https://dev.jobmouka.com

# AI Keys
GEMINI_API_KEY=<your-gemini-api-key>
OPENAI_API_KEY=<your-openai-api-key>

# Google OAuth
GOOGLE_CLIENT_ID=<your-google-client-id>

# Rate limiting
RATE_LIMIT_PER_MINUTE=100
